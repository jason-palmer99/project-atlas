# Project Atlas — Local Environment Configuration
# Copy this file to .env and fill in values:
#   cp .env.example .env

# PostgreSQL (Docker)
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_dev_password
POSTGRES_DB=atlas

# Prisma database connection
DATABASE_URL=postgresql://atlas:atlas_dev_password@localhost:5432/atlas?schema=public

# API
API_PORT=3000

# Auth (disabled for local development)
AUTH_ENABLED=false
